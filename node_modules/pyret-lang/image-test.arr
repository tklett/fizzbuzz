include image
import image-structs as IS
include from IS: color end

c = circle(50, "solid", "red")
c2 = circle(50, "solid", "red")


check:
  image-width(c) is 100
  c is c2
end

check "Overlay equality":
  fun mk-image():
    overlay(circle(100, "solid", "red"), circle(50, "solid", "red"))
  end
  mk-image() is mk-image()
  mk-image() is underlay(circle(50, "solid", "red"), circle(100, "solid", "red"))
end

check "Crop":
  cropsquare = crop(0, 0, 100, 100, rectangle(400, 100, "solid", "red"))
  sq = rectangle(100, 100, "solid", "red")
  cropsquare is sq
end

logo = image-file("img/pyret-logo.png")
check:
  image-width(logo) is 501
  image-height(logo) is 488
  color-at-position(logo, 250, 280) is color(238, 30, 16, 1)
end

save-image(logo, "pyret-logo-copy.png")
logo2 = image-file("pyret-logo-copy.png")
check:
  logo is logo2
end
